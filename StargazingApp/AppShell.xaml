<Shell
    x:Class="StargazingApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:StargazingApp"
    xmlns:views="clr-namespace:StargazingApp.Views"
    Title="StargazingApp"
    Shell.TabBarBackgroundColor="#0F1119"
    Shell.TabBarForegroundColor="#A855F7"
    Shell.TabBarUnselectedColor="#3D4460"
    Shell.TabBarTitleColor="#A855F7">

    <TabBar>
        <ShellContent
            Title="Home"
            Icon="home.png"
            Shell.NavBarIsVisible="False"
            ContentTemplate="{DataTemplate views:MainPage}"
            Route="MainPage" />

        <ShellContent
            Title="Stars"
            Icon="star.png"
            Shell.NavBarIsVisible="False"
            ContentTemplate="{DataTemplate views:ConstellationPage}"
            Route="ConstellationPage" />

        <ShellContent
            Title="Journal"
            Icon="journal.png"
            Shell.NavBarIsVisible="False"
            ContentTemplate="{DataTemplate views:JournalPage}"
            Route="JournalPage" />

        <ShellContent
            Title="Sky Map"
            Icon="telescope.png"
            Shell.NavBarIsVisible="False"
            ContentTemplate="{DataTemplate views:SkyMapPage}"
            Route="SkyMapPage" />
    </TabBar>
</Shell>