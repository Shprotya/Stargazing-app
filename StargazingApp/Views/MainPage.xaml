<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="StargazingApp.Views.MainPage">

    <Grid>
        <Image Grid.Row="0"
           Source="nightsky.jpg"
           Aspect="AspectFill"
           Opacity="0.3" />

        <ScrollView>
            <Grid ColumnDefinitions="2*, *" ColumnSpacing="20" Padding="20">

                <Frame Grid.Column="0" 
                   BackgroundColor="{StaticResource Sections}"
                   CornerRadius="15" Padding="15">
                    <VerticalStackLayout Spacing="15">

                        <ActivityIndicator x:Name="LoadingIndicator"
                           IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           Color="{StaticResource NovaPurple}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />

                        <Label Text="NASA Picture of the Day" 
                               FontSize="20" 
                               FontAttributes="Bold"/>

                        <Label Text="{Binding ApodData.Title}" 
                               FontSize="18" 
                               FontAttributes="Bold"/>
                        <Label Text="{Binding ApodData.Date}" 
                               FontSize="14" 
                               TextColor="{StaticResource OrbitGray}"/>

                        <Frame x:Name="ImageFrame" 
                               Padding="0" 
                               IsClippedToBounds="True" >

                            <Image Source="{Binding ApodData.Url}" 
                                   Aspect="AspectFit" 
                                   HeightRequest="300"/>
                        </Frame>

                        <Label FontSize="12" 
                               Text="{Binding ApodData.Copyright}"
                               TextColor="{StaticResource OrbitGray}"/>

                        <Frame x:Name="ExplanationFrame" 
                               BackgroundColor="{StaticResource Sections}" >
                            <Label Text="{Binding ApodData.Explanation}" FontSize="14"/>
                        </Frame>

                        <!-- Error Message -->
                        <Label x:Name="ErrorLabel"
                           Text="{Binding ErrorMessage}"
                           IsVisible="{Binding HasError}"
                           FontSize="14"
                           TextColor="#EF4444"
                           HorizontalOptions="Center"
                           LineBreakMode="WordWrap"
                           Margin="0,10,0,0"/>

                    </VerticalStackLayout>
                </Frame>

                <VerticalStackLayout Grid.Column="1" Spacing="20">

                    <!-- Date/Time -->
                    <Frame BackgroundColor="{StaticResource Sections}" CornerRadius="15" Padding="15">
                        <Label Text="{Binding CurrentDateTime}" FontSize="14" TextColor="{StaticResource OrbitGray}"/>
                    </Frame>

                    <!-- Moon Phase -->
                    <Frame BackgroundColor="{StaticResource Sections}" CornerRadius="15" Padding="15">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="Moon Phase" FontSize="18" FontAttributes="Bold"/>
                            <HorizontalStackLayout Spacing="10">
                                <Label Text="{Binding MoonPhaseIcon}" FontSize="30"/>
                                <VerticalStackLayout>
                                    <Label Text="{Binding MoonPhaseName}" FontAttributes="Bold"/>
                                    <Label Text="{Binding MoonIllumination}" FontSize="12" TextColor="{StaticResource OrbitGray}"/>
                                </VerticalStackLayout>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Frame>

                    <!-- Tonight's Visibility -->
                    <Frame BackgroundColor="{StaticResource Sections}" CornerRadius="15" Padding="15">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="Tonight's Visibility" FontSize="18" FontAttributes="Bold"/>
                            <Label Text="{Binding VisibilityRating}" FontSize="16"/>

                            <!-- Sunrise / Sunset row -->
                            <HorizontalStackLayout Spacing="20" Margin="0,5,0,0">
                                <HorizontalStackLayout Spacing="6">
                                    <Label Text="🌅" FontSize="16"/>
                                    <VerticalStackLayout>
                                        <Label Text="Sunrise" FontSize="10" TextColor="{StaticResource OrbitGray}"/>
                                        <Label Text="{Binding SunriseTime}" FontSize="14" FontAttributes="Bold"/>
                                    </VerticalStackLayout>
                                </HorizontalStackLayout>

                                <HorizontalStackLayout Spacing="6">
                                    <Label Text="🌇" FontSize="16"/>
                                    <VerticalStackLayout>
                                        <Label Text="Sunset" FontSize="10" TextColor="{StaticResource OrbitGray}"/>
                                        <Label Text="{Binding SunsetTime}" FontSize="14" FontAttributes="Bold"/>
                                    </VerticalStackLayout>
                                </HorizontalStackLayout>
                            </HorizontalStackLayout>

                        </VerticalStackLayout>
                    </Frame>

                    <!-- Tonight's Best Constellations -->
                    <Frame BackgroundColor="{StaticResource Sections}"
                        CornerRadius="15"
                        Padding="15"
                        IsVisible="{Binding HasTonightsBest}">
                        <VerticalStackLayout Spacing="10">

                            <Label Text="⭐ Tonight's Best"
                                FontSize="18"
                                FontAttributes="Bold"/>

                            <Label x:Name="TonightMonthLabel"
                                FontSize="11"
                                TextColor="{StaticResource OrbitGray}"/>

                            <CollectionView x:Name="TonightsBestList"
                                        ItemsSource="{Binding TonightsBest}"
                                        SelectionMode="None">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Frame BackgroundColor="{StaticResource Button}"
                                            CornerRadius="8"
                                            Padding="10,8"
                                            Margin="0,0,0,6">
                                            <Frame.GestureRecognizers>
                                                <TapGestureRecognizer
                                                Command="{Binding BindingContext.SelectConstellationCommand, Source={x:Reference TonightsBestList}}"
                                                CommandParameter="{Binding Name}" />
                                            </Frame.GestureRecognizers>
                                            <Grid ColumnDefinitions="*,Auto">
                                                <VerticalStackLayout Grid.Column="0" Spacing="2">
                                                    <Label Text="{Binding Name}"
                                                        FontSize="14"
                                                        FontAttributes="Bold"/>
                                                    <Label Text="{Binding Hemisphere, StringFormat='🌍 {0}'}"
                                                        FontSize="11"
                                                        TextColor="{StaticResource OrbitGray}"/>
                                                </VerticalStackLayout>
                                                <Label Grid.Column="1"
                                                    Text="›"
                                                    FontSize="20"
                                                    TextColor="{StaticResource NovaPurple}"
                                                    VerticalOptions="Center"/>
                                            </Grid>
                                        </Frame>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>

                        </VerticalStackLayout>
                    </Frame>

                        <!-- Upcoming Events -->
                    <Frame BackgroundColor="{StaticResource Sections}" CornerRadius="15" Padding="15">
                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding UpcomingEvents}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <Label Text="{Binding StringFormat='• {0}'}" FontSize="13"/>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </Frame>

                </VerticalStackLayout>
            </Grid>
        </ScrollView>

    </Grid>

</ContentPage>
