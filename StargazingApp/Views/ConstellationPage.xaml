<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="StargazingApp.Views.ConstellationPage"
             Title="Constellations">

    <Grid>
        <Image Grid.Row="0"
       Source="nightsky.jpg"
       Aspect="AspectFill"
       Opacity="0.3" />

        <Grid RowDefinitions="Auto,*" Padding="20">

            <!-- Search and Filter Section -->
            <VerticalStackLayout Grid.Row="0" Spacing="10" Margin="0,0,0,20">

                <!-- Search Bar -->
                <SearchBar x:Name="SearchBar"
                    Text="{Binding SearchText, Mode=TwoWay}"
                    Placeholder="Search constellations..."
                    TextChanged="OnSearchTextChanged"
                    SearchCommand="{Binding SearchCommand}"/>

                <!--Filtering buttons-->
                <HorizontalStackLayout Spacing="10">
                    <Button x:Name="BtnAll" 
                    Text="All" 
                    Command="{Binding LoadAllCommand}" />

                    <Button x:Name="BtnNorth" 
                    Text="Northern" 
                    Command="{Binding FilterByHemisphereCommand}" 
                    CommandParameter="Northern" />

                    <Button x:Name="BtnSouth" 
                    Text="Southern" 
                    Command="{Binding FilterByHemisphereCommand}" 
                    CommandParameter="Southern" />

                    <Button x:Name="BtnFav" 
                    Text="Favorites" 
                    Command="{Binding FilterFavoritesCommand}" />
                </HorizontalStackLayout>
            </VerticalStackLayout>

            <!-- Constellation Grid Gallery -->
            <CollectionView x:Name="ConstellationList" 
                        Grid.Row="1"
                        SelectionMode="None"
                        ItemsSource="{Binding Constellations}">
                <CollectionView.ItemsLayout>
                    <!-- Responsive columns: 2 on phones, 3 on tablets, 4-5 on desktop -->
                    <GridItemsLayout Orientation="Vertical" 
                         Span="{OnIdiom Phone=2, Tablet=3, Desktop=4, Default=3}"
                         HorizontalItemSpacing="12"
                         VerticalItemSpacing="16" />
                </CollectionView.ItemsLayout>

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Padding="12"
                           CornerRadius="10"
                           BackgroundColor="{StaticResource Sections}"
                           HasShadow="True">

                            <!-- Make the whole card tappable -->
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer 
                                    Command="{Binding BindingContext.ShowDetailsCommand, Source={x:Reference ConstellationList}}"
                                    CommandParameter="{Binding .}" />
                            </Frame.GestureRecognizers>

                            <Grid RowDefinitions="Auto,120,Auto,Auto,Auto" RowSpacing="8">

                                <!-- Constellation Name -->
                                <Label Grid.Row="0"
                                   Text="{Binding Name}"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   HorizontalTextAlignment="Center"
                                   LineBreakMode="TailTruncation" />

                                <!-- Image Container -->
                                <Border Grid.Row="1"
                                    StrokeThickness="0"
                                    BackgroundColor="{StaticResource Main}"
                                    Padding="5">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="8" />
                                    </Border.StrokeShape>
                                    <Image Source="{Binding ImageUrl}"
                                       Aspect="AspectFit" />
                                </Border>

                                <!-- Description -->
                                <Label Grid.Row="2"
                                   Text="{Binding Description}"
                                   FontSize="11"
                                   TextColor="{StaticResource OrbitGray}"
                                   LineBreakMode="TailTruncation"
                                   MaxLines="3"
                                   HeightRequest="32" />

                                <!-- Extra info row -->
                                <VerticalStackLayout Grid.Row="3" Spacing="2">
                                    <Label FontSize="10"
                                       TextColor="{StaticResource OrbitGray}"
                                       Text="{Binding Abbreviation, StringFormat='Abbreviation: {0}'}" />

                                    <Label FontSize="10"
                                       TextColor="{StaticResource OrbitGray}"
                                       Text="{Binding BestVisibleMonth, StringFormat='Best month: {0}'}" />

                                    <Label FontSize="10"
                                       TextColor="{StaticResource OrbitGray}"
                                       Text="{Binding Hemisphere, StringFormat='Hemisphere: {0}'}" />

                                    <Label FontSize="10"
                                       TextColor="{StaticResource OrbitGray}"
                                       Text="{Binding NumberOfStars, StringFormat='Stars: {0}'}" />

                                    <Label FontSize="10"
                                       TextColor="{StaticResource OrbitGray}"
                                       Text="{Binding Area, StringFormat='Area: {0} sq deg'}" />
                                </VerticalStackLayout>

                                <!-- Bottom: Star info and Favorite -->
                                <Grid Grid.Row="4" ColumnDefinitions="*,Auto">
                                    <!-- Brightest Star -->
                                    <Label Grid.Column="0"
                                       FontSize="10"
                                       TextColor="{StaticResource OrbitGray}"
                                       VerticalOptions="Center"
                                       LineBreakMode="TailTruncation">
                                        <Label.FormattedText>
                                            <FormattedString>
                                                <Span Text="⭐ " />
                                                <Span Text="{Binding BrightestStar}" />
                                            </FormattedString>
                                        </Label.FormattedText>
                                    </Label>

                                    <!-- Favorite Button -->
                                    <Button Grid.Column="1"
                                        FontSize="20"
                                        BackgroundColor="Transparent"
                                        Command="{Binding BindingContext.ToggleFavoriteCommand, Source={x:Reference SearchBar}}"
                                        CommandParameter="{Binding Id}"
                                        Padding="0"
                                        Margin="-10,0,0,0"
                                        WidthRequest="35"
                                        HeightRequest="35">
                                        <Button.Triggers>
                                            <DataTrigger TargetType="Button"
                                                 Binding="{Binding IsFavorite}"
                                                 Value="True">
                                                <Setter Property="Text" Value="⭐" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Button"
                                                 Binding="{Binding IsFavorite}"
                                                 Value="False">
                                                <Setter Property="Text" Value="☆" />
                                            </DataTrigger>
                                        </Button.Triggers>
                                    </Button>
                                </Grid>

                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </Grid>
    </Grid>
</ContentPage>
