<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="StargazingApp.Views.ConstellationPage"
             Title="Constellations"
             BackgroundColor="{StaticResource Main}">

    <Grid RowDefinitions="Auto,*" Padding="20">

        <!-- Search and Filter Section -->
        <VerticalStackLayout Grid.Row="0" Spacing="10" Margin="0,0,0,20">

            <!-- Search Bar -->
            <SearchBar x:Name="SearchBar"
                      Placeholder="Search constellations..."
                      TextColor="{StaticResource StarWhite}"
                      PlaceholderColor="{StaticResource OrbitGray}"
                      BackgroundColor="{StaticResource Sections}"
                      SearchButtonPressed="OnSearchButtonPressed"
                      TextChanged="OnSearchTextChanged"/>

            <!-- Filter Buttons -->
            <HorizontalStackLayout Spacing="10">
                <Button x:Name="BtnAll" 
                        Text="All" 
                        Clicked="OnFilterAll" 
                        BackgroundColor="{StaticResource NovaPurple}"/>
                <Button x:Name="BtnNorth" 
                        Text="Northern" 
                        Clicked="OnFilterNorthern" 
                        BackgroundColor="{StaticResource Button}"/>
                <Button x:Name="BtnSouth" 
                        Text="Southern" 
                        Clicked="OnFilterSouthern" 
                        BackgroundColor="{StaticResource Button}"/>
                <Button x:Name="BtnFav" 
                        Text="Favorites" 
                        Clicked="OnFilterFavorites" 
                        BackgroundColor="{StaticResource Button}"/>
            </HorizontalStackLayout>
        </VerticalStackLayout>

        <!-- Constellation List -->
        <CollectionView x:Name="ConstellationList" 
                       Grid.Row="1"
                       SelectionMode="Single"
                       SelectionChanged="OnConstellationSelected">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="0,0,0,15" 
                          Padding="15"
                          BackgroundColor="{StaticResource Sections}">
                        <Grid ColumnDefinitions="80,*,Auto" ColumnSpacing="15">

                            <!-- Constellation Image -->
                            <Frame Grid.Column="0" 
                                  Padding="5"
                                  CornerRadius="8"
                                  BackgroundColor="{StaticResource Main}">
                                <Image Source="{Binding ImageUrl}"
                                      Aspect="AspectFit"
                                      HeightRequest="60"
                                      WidthRequest="60"/>
                            </Frame>

                            <!-- Constellation Info -->
                            <VerticalStackLayout Grid.Column="1" Spacing="5">
                                <Label Text="{Binding Name}" 
                                      FontSize="18" 
                                      FontAttributes="Bold"/>

                                <Label FontSize="12" TextColor="{StaticResource OrbitGray}">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="⭐ "/>
                                            <Span Text="{Binding BrightestStar}"/>
                                            <Span Text=" • "/>
                                            <Span Text="{Binding NumberOfStars}"/>
                                            <Span Text=" stars"/>
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>

                                <Label FontSize="12" TextColor="{StaticResource OrbitGray}">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="🌍 "/>
                                            <Span Text="{Binding Hemisphere}"/>
                                            <Span Text=" • 📅 "/>
                                            <Span Text="{Binding BestVisibleMonth}"/>
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>

                                <Label Text="{Binding Description}" 
                                      FontSize="13" 
                                      TextColor="{StaticResource OrbitGray}"
                                      LineBreakMode="TailTruncation"
                                      MaxLines="2"/>
                            </VerticalStackLayout>

                            <!-- Favorite Button -->
                            <Button Grid.Column="2"
                                   Text="{Binding IsFavorite, Converter={StaticResource FavoriteIconConverter}}"
                                   FontSize="24"
                                   BackgroundColor="Transparent"
                                   Clicked="OnFavoriteClicked"
                                   CommandParameter="{Binding Id}"
                                   WidthRequest="50"
                                   HeightRequest="50"/>
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>
